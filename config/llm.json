{
  "providers": {
    "groq": {
      "api_url": "https://api.groq.com/openai/v1/chat/completions",
      "api_key_env": "GROQ_API_KEY",
      "format": "openai_compat"
    },
    "openai": {
      "api_url": "https://api.openai.com/v1/chat/completions",
      "api_key_env": "OPENAI_API_KEY",
      "format": "openai_compat"
    },
    "anthropic": {
      "api_url": "https://api.anthropic.com/v1/messages",
      "api_key_env": "ANTHROPIC_API_KEY",
      "format": "anthropic"
    }
  },
  "models": {
    "assistant_default": {
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "temperature": 0.3,
      "max_tokens": 1024,
      "price_per_million_input_usd": 0.59,
      "price_per_million_output_usd": 0.79
    },
    "analysis_default": {
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "temperature": 0.2,
      "max_tokens": 1500,
      "price_per_million_input_usd": 0.59,
      "price_per_million_output_usd": 0.79
    },
    "smart_prompt_default": {
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "temperature": 0.7,
      "max_tokens": 2000,
      "price_per_million_input_usd": 0.59,
      "price_per_million_output_usd": 0.79
    },
    "persona_default": {
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "temperature": 0.8,
      "max_tokens": 2500,
      "price_per_million_input_usd": 0.59,
      "price_per_million_output_usd": 0.79
    },
    "smart_prompt_openai": {
      "provider": "openai",
      "model": "gpt-4o-mini",
      "temperature": 0.7,
      "max_tokens": 2000,
      "price_per_million_input_usd": 0.15,
